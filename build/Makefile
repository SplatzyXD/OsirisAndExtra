# target to preprocess a source file
Osiris/imguiCustom.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Osiris.dir/build.make CMakeFiles/Osiris.dir/Osiris/imguiCustom.cpp.i
.PHONY : Osiris/imguiCustom.cpp.i

Osiris/imguiCustom.s: Osiris/imguiCustom.cpp.s
.PHONY : Osiris/imguiCustom.s

# target to generate assembly for a file
Osiris/imguiCustom.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Osiris.dir/build.make CMakeFiles/Osiris.dir/Osiris/imguiCustom.cpp.s
.PHONY : Osiris/imguiCustom.cpp.s

